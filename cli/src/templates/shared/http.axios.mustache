import axios, { AxiosError, type AxiosRequestConfig } from 'axios'
import { HttpError } from '../errors/HttpError'
import { NetworkError } from '../errors/NetworkError'

declare const __DEV__: boolean

const BASE_URL = process.env.EXPO_PUBLIC_API_URL ?? ''

function extractErrorMessage(data: unknown, fallback: string): string {
  if (typeof data === 'string') return data
  if (data && typeof data === 'object') {
    const obj = data as Record<string, unknown>
    if (typeof obj.message === 'string') return obj.message
    if (typeof obj.error === 'string') return obj.error
    try { return JSON.stringify(data) } catch { /* empty */ }
  }
  return fallback
}

const requestTimings = new Map<string, number>()

const instance = axios.create({
  baseURL: BASE_URL,
  headers: { 'Content-Type': 'application/json' },
})

// ─── Auth ────────────────────────────────────────────────────────────
let authToken: string | null = null

export function setAuthToken(token: string | null) {
  authToken = token
}

// ─── Request Interceptors ────────────────────────────────────────────
instance.interceptors.request.use((config) => {
  if (__DEV__) {
    const method = config.method?.toUpperCase() ?? '?'
    const url = `${config.baseURL ?? ''}${config.url ?? ''}`
    const requestId = `${method}:${url}:${Date.now()}`
    config.headers.set('X-Request-Id', requestId)
    requestTimings.set(requestId, Date.now())
    console.log(`→ ${method} ${url}`)
    if (config.data) console.log('  Body:', JSON.stringify(config.data))
  }

  if (authToken) {
    config.headers.Authorization = `Bearer ${authToken}`
  }

  return config
})

// ─── Response Interceptors ───────────────────────────────────────────
instance.interceptors.response.use(
  (response) => {
    if (__DEV__) {
      const requestId = response.config.headers.get('X-Request-Id') as string | undefined
      const start = requestId ? requestTimings.get(requestId) : undefined
      const duration = start ? Date.now() - start : 0
      if (requestId) requestTimings.delete(requestId)
      console.log(`← ${response.status} (${duration}ms)`)
    }
    return response
  },
  (error) => {
    if (__DEV__ && error instanceof AxiosError) {
      const requestId = error.config?.headers?.get?.('X-Request-Id') as string | undefined
      const start = requestId ? requestTimings.get(requestId) : undefined
      const duration = start ? Date.now() - start : 0
      if (requestId) requestTimings.delete(requestId)
      const status = error.response?.status ?? 'NETWORK_ERROR'
      console.log(`← ${status} (${duration}ms)`)
      if (error.response?.data) console.log('  Error:', JSON.stringify(error.response.data))
    }

    return Promise.reject(error)
  }
)

// ─── Request Helper ──────────────────────────────────────────────────
async function request<T>(config: AxiosRequestConfig): Promise<T> {
  try {
    const response = await instance(config)
    return response.data as T
  } catch (error) {
    if (error instanceof AxiosError) {
      if (error.response) {
        throw new HttpError(
          error.response.status,
          extractErrorMessage(error.response.data, error.message)
        )
      }
      throw new NetworkError(error.message)
    }
    throw new NetworkError()
  }
}

export const httpClient = {
  get<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'GET', url: path, headers })
  },

  post<T>(
    path: string,
    data: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({ method: 'POST', url: path, data, headers })
  },

  patch<T>(
    path: string,
    data: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({ method: 'PATCH', url: path, data, headers })
  },

  put<T>(
    path: string,
    data: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({ method: 'PUT', url: path, data, headers })
  },

  delete<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'DELETE', url: path, headers })
  },
}
