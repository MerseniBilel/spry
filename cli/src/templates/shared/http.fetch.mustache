import { HttpError } from '../errors/HttpError'
import { NetworkError } from '../errors/NetworkError'

declare const __DEV__: boolean

const BASE_URL = process.env.EXPO_PUBLIC_API_URL ?? ''

function extractErrorMessage(raw: string): string {
  try {
    const parsed = JSON.parse(raw)
    if (typeof parsed === 'string') return parsed
    if (typeof parsed.message === 'string') return parsed.message
    if (typeof parsed.error === 'string') return parsed.error
    return raw
  } catch {
    return raw
  }
}

interface RequestConfig {
  method: string
  path: string
  headers?: Record<string, string>
  body?: string
}

// ─── Interceptors ────────────────────────────────────────────────────
type RequestInterceptor = (config: RequestConfig) => RequestConfig
type ResponseInterceptor = (
  response: { status: number; ok: boolean; errorBody?: string },
  config: RequestConfig,
  durationMs: number
) => void

const requestInterceptors: RequestInterceptor[] = []
const responseInterceptors: ResponseInterceptor[] = []

// Dev logger
if (__DEV__) {
  requestInterceptors.push((config) => {
    const url = `${BASE_URL}${config.path}`
    console.log(`→ ${config.method} ${url}`)
    if (config.body) console.log('  Body:', config.body)
    return config
  })

  responseInterceptors.push((response, _config, durationMs) => {
    console.log(`← ${response.status} (${durationMs}ms)`)
    if (!response.ok && response.errorBody) {
      console.log('  Error:', response.errorBody)
    }
  })
}

// ─── Auth ────────────────────────────────────────────────────────────
let authToken: string | null = null

export function setAuthToken(token: string | null) {
  authToken = token
}

requestInterceptors.push((config) => {
  if (authToken) {
    config.headers = {
      ...config.headers,
      Authorization: `Bearer ${authToken}`,
    }
  }
  return config
})

// ─── Request Helper ──────────────────────────────────────────────────
async function request<T>(initialConfig: RequestConfig): Promise<T> {
  let config = initialConfig
  for (const interceptor of requestInterceptors) {
    config = interceptor(config)
  }

  const url = `${BASE_URL}${config.path}`
  const startTime = Date.now()
  let response: Response

  try {
    response = await fetch(url, {
      method: config.method,
      headers: {
        'Content-Type': 'application/json',
        ...config.headers,
      },
      body: config.body,
    })
  } catch {
    const durationMs = Date.now() - startTime
    for (const interceptor of responseInterceptors) {
      interceptor({ status: 0, ok: false }, config, durationMs)
    }
    throw new NetworkError()
  }

  if (!response.ok) {
    const rawBody = await response.text().catch(() => 'Unknown error')
    const errorMessage = extractErrorMessage(rawBody)
    const durationMs = Date.now() - startTime
    for (const interceptor of responseInterceptors) {
      interceptor({ status: response.status, ok: false, errorBody: errorMessage }, config, durationMs)
    }
    throw new HttpError(response.status, errorMessage)
  }

  const durationMs = Date.now() - startTime
  for (const interceptor of responseInterceptors) {
    interceptor({ status: response.status, ok: true }, config, durationMs)
  }

  return response.json() as Promise<T>
}

export const httpClient = {
  get<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'GET', path, headers })
  },

  post<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'POST',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  patch<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'PATCH',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  put<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'PUT',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  delete<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'DELETE', path, headers })
  },
}
