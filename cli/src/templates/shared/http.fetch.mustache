// ─── Request Helper ──────────────────────────────────────────────────
async function request<T>(initialConfig: RequestConfig): Promise<T> {
  let config = initialConfig
  for (const interceptor of requestInterceptors) {
    config = interceptor(config)
  }

  const url = `${BASE_URL}${config.path}`
  const startTime = Date.now()
  let response: Response

  try {
    response = await fetch(url, {
      method: config.method,
      headers: {
        'Content-Type': 'application/json',
        ...config.headers,
      },
      body: config.body,
    })
  } catch {
    const durationMs = Date.now() - startTime
    for (const interceptor of responseInterceptors) {
      interceptor({ status: 0, ok: false }, config, durationMs)
    }
    throw new NetworkError()
  }

  if (!response.ok) {
    const errorBody = await response.text().catch(() => 'Unknown error')
    const durationMs = Date.now() - startTime
    for (const interceptor of responseInterceptors) {
      interceptor({ status: response.status, ok: false, errorBody }, config, durationMs)
    }
    throw new HttpError(response.status, errorBody)
  }

  const durationMs = Date.now() - startTime
  for (const interceptor of responseInterceptors) {
    interceptor({ status: response.status, ok: true }, config, durationMs)
  }

  return response.json() as Promise<T>
}

export const httpClient = {
  get<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'GET', path, headers })
  },

  post<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'POST',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  patch<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'PATCH',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  put<T>(
    path: string,
    body: unknown,
    headers?: Record<string, string>
  ) {
    return request<T>({
      method: 'PUT',
      path,
      headers,
      body: JSON.stringify(body),
    })
  },

  delete<T>(path: string, headers?: Record<string, string>) {
    return request<T>({ method: 'DELETE', path, headers })
  },
}
