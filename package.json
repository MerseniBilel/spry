{
  "name": "spry-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter spry dev",
    "spry": "pnpm --filter spry dev --",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "prettier": "3.8.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
